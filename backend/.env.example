# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/venturelake?schema=public"

# Auth (backend-owned JWT). REQUIRED in production — the app refuses to start
# without it when NODE_ENV=production. Use a long random string.
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
# Set to "production" in deployment (enables the JWT_SECRET + CORS guards).
NODE_ENV="development"

# Comma-separated list of allowed CORS origins (frontend dev server). If unset
# in production, all origins are allowed and a warning is logged — set this.
CORS_ORIGIN="http://localhost:5173"

# Set to "true" when running behind a proxy/load balancer so the rate limiter
# sees the real client IP (app.set("trust proxy", 1)). Leave unset locally.
TRUST_PROXY="false"

# AI provider (used later by src/lib/aiClient). Optional for scaffolding.
AI_API_KEY=""
AI_MODEL="claude-opus-4-8"

# Comma-separated list of emails granted admin access (VC approval, etc.).
ADMIN_EMAILS=""
