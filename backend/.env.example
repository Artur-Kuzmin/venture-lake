# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/venturelake?schema=public"

# Auth (backend-owned JWT)
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000

# Comma-separated list of allowed CORS origins (frontend dev server)
CORS_ORIGIN="http://localhost:5173"

# AI provider (used later by src/lib/aiClient). Optional for scaffolding.
AI_API_KEY=""
AI_MODEL="claude-opus-4-8"

# Comma-separated list of emails granted admin access (VC approval, etc.).
ADMIN_EMAILS=""
