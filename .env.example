# Shared example env for VentureLake.
# Copy the relevant blocks into backend/.env and frontend/.env.
# See backend/.env.example and frontend/.env.example for the per-app copies.

# --- Backend ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/venturelake?schema=public"
# REQUIRED in production (app refuses to start without it when NODE_ENV=production).
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
PORT=4000
# Set to "production" in deployment.
NODE_ENV="development"
# Comma-separated allowed CORS origins; set in production (else all origins allowed + warning).
CORS_ORIGIN="http://localhost:5173"
# "true" when behind a proxy/load balancer so the rate limiter sees the real client IP.
TRUST_PROXY="false"
# Background expiry jobs; default enabled. Set "false" on all but one instance when scaling.
RUN_BACKGROUND_JOBS="true"
# Comma-separated emails granted admin access (VC approval, etc.).
ADMIN_EMAILS=""

# --- Frontend ---
VITE_API_BASE_URL="http://localhost:4000"
