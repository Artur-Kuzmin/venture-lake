# Shared example env for VentureLake.
# Copy the relevant blocks into backend/.env and frontend/.env.
# See backend/.env.example and frontend/.env.example for the per-app copies.

# --- Backend ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/venturelake?schema=public"
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
PORT=4000

# --- Frontend ---
VITE_API_BASE_URL="http://localhost:4000"
