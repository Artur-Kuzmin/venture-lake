{
  "name": "venturelake",
  "version": "0.1.0",
  "private": true,
  "description": "VentureLake — matchmaking-to-execution engine for founders (MVP)",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "install:all": "npm install && npm --prefix backend install && npm --prefix frontend install",
    "prisma:generate": "npm --prefix backend run prisma:generate",
    "prisma:migrate": "npm --prefix backend run prisma:migrate"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
