# Base URL of the VentureLake backend API.
# The variable MUST be named exactly VITE_API_BASE_URL — it is read by
# frontend/src/lib/apiClient.ts. A differently-named var (e.g. VITE_API_URL) is
# ignored and the client silently falls back to http://localhost:4000.
# Vite only exposes VITE_-prefixed vars and bakes them in at dev-server start,
# so restart `npm run dev` after editing this.
VITE_API_BASE_URL="http://localhost:4000"
